---
import { marked } from 'marked';

export interface Props {
    postMetadata: {
        title: string,
        subTitle?: string,
        description: string,
        techStack: string[],
        media: {
            src: string,
            alt: string
        },
        slugDirectory: string,
        slug: string;
    }
    index: number
}

const { postMetadata, index } = Astro.props as Props;
const isVideo = postMetadata.media.src.endsWith(".mp4") || postMetadata.media.src.endsWith(".webm");
---

<article class:list={["mb-10 md:mb-14 no-underline text-current"]}>
    <div class:list={["project-card", { "project-card--reverse": index % 2 === 1 }]}>
        <div class="project-card__media">
            {
                isVideo ?
                <video class="project-card__asset" src={postMetadata.media.src} width="640" height="360" autoplay muted loop playsinline>
                    Your browser does not support the video tag.
                </video>
                :
                <img class="project-card__asset" src={postMetadata.media.src} alt={postMetadata.media.alt} loading="lazy" />
            }
        </div>

        <div class="pt-1 px-2 pb-2 md:px-3 md:py-2">
            <div class="mb-4">
                <p class="label-md text-gray-400 uppercase">{postMetadata.subTitle}</p>
                <h3 class="h3">{postMetadata.title}</h3>
            </div>

            <div class="prose" set:html={marked.parse(postMetadata.description, {breaks: true, gfm: true})}></div>

            <div class="mt-4 mb-6">
                <ul class="list-none flex flex-wrap horizontal-list">
                    {postMetadata.techStack.map(tech => (
                        <li class="label-md">{tech}</li>
                    ))}
                </ul>
            </div>

            <div class="flex max-md:justify-center">
                <a class="btn-bevel btn-bevel-primary" href={postMetadata.slugDirectory + postMetadata.slug}>
                    Read more
                </a>
            </div>
        </div>
    </div>
</article>

<style>

  /* Project feature cards (alternating side, no bleed) */
  .project-card {
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    padding: 1.1rem;
    background: var(--color-pastel-light-yellow);
    border: 3px solid var(--color-secondary);
    border-radius: 7px;
    transition: transform 0.25s ease, box-shadow 0.25s ease;
  }
  .project-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 46px -14px rgba(74, 48, 24, 0.34), 0 2px 0 0 rgba(0, 0, 0, 0.02);
  }
  @media (prefers-reduced-motion: reduce) {
    .project-card { transition: none; }
    .project-card:hover { transform: none; }
  }

  .project-card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: #ece9e4;
    border-radius: 4px;
    align-self: center;
    box-shadow: inset 0 0 0 1px rgba(0, 0, 0, 0.06);
  }
  .project-card__asset {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  @media (min-width: 1024px) {
    .project-card {
      grid-template-columns: 1.08fr 1fr;
      gap: 2.5rem;
      padding: 1.4rem;
    }
    .project-card--reverse .project-card__media { order: 2; }
  }


  .taglist {
    display: inline;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  
  .taglist li {
    display: inline;
  }
</style>