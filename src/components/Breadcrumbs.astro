---
export interface Props {
    items: {
        href: string,
        text: string
    }[];
}

let model = Astro.props as Props;
---
{
model.items.length ?
    <nav aria-label="Breadcrumb" class="breadcrumbs">
        {
            model.items.flatMap((item, i) => {
                const isLast = i === model.items.length - 1;
                return [
                    isLast
                        ? <span aria-current="page">{item.text}</span>
                        : <a href={item.href}>{item.text}</a>,
                    !isLast ? <span class="breadcrumbs__sep" aria-hidden="true">›</span> : null
                ];
            })
        }
    </nav>
    : null
}
