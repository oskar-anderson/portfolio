---
import '/src/styles/global.css'

const { isHome = false } = Astro.props;
---

<header
    class:list={[
        'bg-secondary',
        { 'absolute z-20 right-0 left-0 backdrop-filter-[10px]': isHome },
    ]}
>
    <div class="container py-5 flex items-center justify-between">
        <h1 class="h1" style={{ marginBottom: 0, textAlign: "center", fontSize: "1.5em" }}>
            <a style={{ textDecoration: "none" }} href="/">Karl Oskar</a>
        </h1>
        <ul class="flex flex-row list-none">
            <li class="mx-4">
                <a href="/">Home</a>
            </li>
            <li class="mx-4">
                <a href="/blog">Blog</a>
            </li>
            <li class="mx-4">
                <a href="/work">Work</a>
            </li>
            <li class="mx-4">
                <a href="/contact">Contact</a>
            </li>
        </ul>
    </div>
</header>