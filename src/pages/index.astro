---
import PostPreview from '../components/PostPreview.astro';
import Testimonial from '../components/Testimonial';
import { SkillCardFrontend, SkillCardBackend, SkillCardTools } from '../components/SkillCard';
import Layout from '../layouts/Layout.astro';

let allPosts = Object.values(import.meta.glob<Record<string, any>>("../posts/*.md", { eager: true }))
let postsToShow = ["estravel-fullstack", "estravel", "charon", "HedgehogDBD", "tempsens", "maanteeamet-timescanner"].map(postToShow => {
	return allPosts.filter(x => x.frontmatter.slug === postToShow)[0]
});

let isAvailableForWork = false;
---

<Layout>
    <div>
		<section class="relative overflow-hidden mt-[76px] min-h-[calc(100vh-76px)] flex flex-col justify-center text-white is-dark">
			<canvas id="hero-canvas" class="absolute inset-0 min-w-full min-h-full w-auto h-auto max-w-none aspect-video z-[-1] bg-[#58cce4] pointer-events-none" aria-hidden="true"></canvas>
			<div class="absolute inset-0 z-[-1] pointer-events-none" style="background: radial-gradient(115% 115% at 88% 8%, transparent 38%, rgba(6, 24, 30, 0.65) 100%);" aria-hidden="true"></div>

			<a class="hidden absolute bottom-6 left-1/2 -translate-x-1/2 md:flex flex-col items-center gap-2" href="#skills" aria-label="Scroll to about">
				<span class="font-mono text-white tracking-[2.5px] text-xs uppercase">scroll</span>
				<svg class="w-4 h-4 animate-bounce text-white" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
					<path d="M12 5v14"></path>
					<path d="m19 12-7 7-7-7"></path>
				</svg>
			</a>
			
			<div class="container flex gap-12 pt-16 pb-24">

				<div class="flex flex-col md:flex-row md:items-center md:justify-between gap-10 w-full text-center md:text-left">

					<div class="shrink-0 md:hidden">
						<img class="w-72 md:w-96 mx-auto rotate-3 rounded-md border-4 border-white bg-white shadow-xl" src="/static/img/Estravel_29_01_2026_HD-143_portrait.jpg" draggable="false">
					</div>

					<div class="flex flex-col gap-5 items-center md:items-start">

						{ isAvailableForWork && <span class="notice-stamp notice-stamp-available-for-work">
							Available for work
						</span>}

						<span class="text-primary text-[42px] leading-tight font-extrabold max-w-[10ch]" style="font-size: clamp(2.6rem, 8vw, 5.2rem); line-height: 0.98;">
							Karl Oskar Anderson
						</span>
						
						<div class="font-medium max-md" style="font-size: clamp(1.3rem, 3.2vw, 2rem); max-width: 22ch;">
							I build the web at <strong>Estravel</strong>;
							from client-facing services to 
							internal offer creation engines
						</div>

						<div class="flex flex-col w-64 text-base gap-4 mt-6">
							<a class="btn-bevel btn-bevel-primary" href="#">
								Resume TODO LINK
							</a>
							<!--
							<a class="btn-bevel btn-bevel-secondary" href="#">
								Contact TODO LINK
							</a>
							-->
						</div>

						<div class="inline-flex mt-4">
							<span class="inline-flex  items-center gap-2 mr-5">
								<svg class="w-4 h-4 text-white" viewBox="0 0 384 512" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
									<path d="M0 188.6C0 84.4 86 0 192 0S384 84.4 384 188.6c0 119.3-120.2 262.3-170.4 316.8-11.8 12.8-31.5 12.8-43.3 0-50.2-54.5-170.4-197.5-170.4-316.8zM192 256a64 64 0 1 0 0-128 64 64 0 1 0 0 128z"/>
								</svg>
								<span>Tallinn</span>
							</span>

							<div class="flex gap-2">
								<a href="https://github.com/oskar-anderson/" class="btn-icon btn-brand-github" aria-label="GitHub">
									<svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
										<path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/>
									</svg>
								</a>
								<a href="https://www.linkedin.com/in/karl-oskar-anderson" class="btn-icon btn-brand-linkedin" aria-label="LinkedIn">
									<svg class="w-8 h-8" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
										<path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
									</svg>
								</a>
								<a href="mailto:andersonkarloskar@gmail.com" class="btn-icon btn-brand-email" aria-label="Email">
									<svg class="w-8 h-8" viewBox="0 0 512 512" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
										<path d="M48 64c-26.5 0-48 21.5-48 48 0 15.1 7.1 29.3 19.2 38.4l208 156c17.1 12.8 40.5 12.8 57.6 0l208-156c12.1-9.1 19.2-23.3 19.2-38.4 0-26.5-21.5-48-48-48L48 64zM0 196L0 384c0 35.3 28.7 64 64 64l384 0c35.3 0 64-28.7 64-64l0-188-198.4 148.8c-34.1 25.6-81.1 25.6-115.2 0L0 196z"/>
									</svg>
								</a>
							</div>
						</div>

					</div>

					<div class="shrink-0 hidden md:block">
						<img class="w-72 md:w-96 mx-auto rotate-3 rounded-md border-4 border-white bg-white shadow-xl" src="/static/img/Estravel_29_01_2026_HD-143_portrait.jpg" draggable="false">
					</div>

					<!-- 

					<span class="text-lg font-semibold">I'm Karl Oskar Anderson and I develop web applications</span><br>
		
					<h1 class="text-[4rem] font-bold">
						with modern <span class="vue-to-react-highlight-gradient">SPA frameworks</span>
						and <span class="mysql-highlight-gradient">relational databases</span>
					</h1>

					<h2 class="text-[1.5rem] mt-10 font-semibold">
						Full Stack Developer
					</h2>



					with <span class="laravel-highlight-gradient whitespace-nowrap">PHP/Laravel</span> and modern JavaScript frameworks 
					(<span class="vue-highlight-gradient">Vue</span>,
					<span class="react-highlight-gradient">React</span>)


					<h1 class="text-[3.75rem] font-bold">
						web applications with
						<span class="vue-highlight-gradient">Vue</span>,
						<span class="react-highlight-gradient">React</span> and
						<span class="laravel-highlight-gradient">PHP</span>
					</h1>

					<h2 class="text-[1.5rem] mt-10 font-semibold">
						Frontend Developer
					</h2>


					everything with a frontend from browser extensions, 

					I create web applications, browser extensions, and API integrations. Currently building web at Estravel.
					I build web at Estravel
		
					I'm a web developer living in Tallinn
					-->
				</div>
			</div>
		</section>
  
		<section class="section pb-0 is-light">

			<div class="container">
				<h2 class="display-md text-center mb-16" id="skills">Skills</h2>
				<div class="container flex flex-col md:flex-row flex-wrap max-md:items-center md:justify-center gap-x-8 gap-y-8">
					<div class="js-gsap-card max-w-[360px]">
						<SkillCardFrontend className='rotate-[-0.8deg] hover:rotate-0' title='Frontend' text='Creating fast, responsive interfaces with reusable components and modern CSS workflows.'></SkillCardFrontend>
					</div>
					<div class="js-gsap-card max-w-[360px]">
						<SkillCardBackend className='rotate-[1deg] hover:rotate-0' title='Backend' text='Adapting backend solutions to the problem - using WordPress for CMS, Laravel for applications, Python for data-driven tasks and .NET for business logic.'></SkillCardBackend>
					</div>
					<div class="js-gsap-card max-w-[360px]">
						<SkillCardTools className='rotate-[-1.2deg] hover:rotate-0' title='Tools' text='Turning "it works on my machine" into "it works everywhere".'></SkillCardTools>
					</div>
					
				</div>
			</div>
  
		</section>

		<section class="section is-light">
			<div>
				<h2 class="display-md text-center mb-16">Projects</h2>
				{postsToShow.map((project, i) =>
					<PostPreview index={i} postMetadata={project.frontmatter as any} />
				)}
			</div>
		</section>

		<Testimonial client:load></Testimonial>
	</div>
</Layout>

<script>
	import gsap from "gsap";
	import { ScrollTrigger } from "gsap/ScrollTrigger";

	gsap.registerPlugin(ScrollTrigger);


	if (window.innerWidth > 1224) {
		const cards = gsap.utils.toArray(".js-gsap-card");
		cards.forEach((card, i) => {
			gsap.fromTo(
				card,
				{
					x: (2 - i - 1) * 320,
				},
				{
					x: 0,
					ease: "back.out",
					scrollTrigger: {
						trigger: card,
						start: "top 80%",
						end: "top 80%",
					}
				}
			);
		});
	}
</script>

<script>
	import { initHeroShader } from "../shaders/hero/heroShader";
	initHeroShader();
</script>