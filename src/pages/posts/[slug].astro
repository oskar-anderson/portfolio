---
import Breadcrumbs from "../../components/Breadcrumbs.astro"
import LayoutWithMarkdown from "../../layouts/LayoutWithMarkdown.astro";

export async function getStaticPaths() {
    const posts = Object.values(import.meta.glob<Record<string, any>>("../../posts/*.md", { eager: true }));

    return posts.map(post => ({
        params: {
            slug: post.frontmatter.slug
        },
        props: {
            post
        }
    }));
};

const { Content, frontmatter } = Astro.props.post;
---

<LayoutWithMarkdown>
    <div class="content-container mb-12">
        <Breadcrumbs items={[
            { href: "/", text: "Home"},
            { href: "/" + frontmatter.slugDirectory + frontmatter.slug, text: frontmatter.title},
        ]} />
        <div class="mt-6 mb-4">
            <h1>{frontmatter.title}</h1>
        </div>
        <div class="markdown">
            <Content />
        </div>

    </div>
</LayoutWithMarkdown>
