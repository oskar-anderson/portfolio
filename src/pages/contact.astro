---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <section class="section content-container is-light">
        <div class="flex gap-20">
            <div class="flex flex-col gap-6 max-w-[48ch]">
                <h2 class="display-md">Contact</h2>

                <p class="body-lg">
                    Have feedback, a suggestion, or a question? The quickest way to
                    reach me is by email, or say hello on LinkedIn.
                </p>

                <div class="flex flex-wrap gap-4">
                    <a
                        class="btn-bevel btn-brand-email inline-flex items-center justify-center gap-2"
                        href="mailto:andersonkarloskar@gmail.com?subject=Contact Request"
                    >
                        <svg class="w-5 h-5" viewBox="0 0 512 512" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M48 64c-26.5 0-48 21.5-48 48 0 15.1 7.1 29.3 19.2 38.4l208 156c17.1 12.8 40.5 12.8 57.6 0l208-156c12.1-9.1 19.2-23.3 19.2-38.4 0-26.5-21.5-48-48-48L48 64zM0 196L0 384c0 35.3 28.7 64 64 64l384 0c35.3 0 64-28.7 64-64l0-188-198.4 148.8c-34.1 25.6-81.1 25.6-115.2 0L0 196z"/>
                        </svg>
                        Email me
                    </a>
                    <a
                        class="btn-bevel btn-brand-linkedin inline-flex items-center justify-center gap-2"
                        href="https://www.linkedin.com/in/karl-oskar-anderson"
                        target="_blank"
                        rel="noopener"
                    >
                        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                        </svg>
                        LinkedIn
                    </a>
                </div>

                <p class="body-md">
                    Spotted a typo or something out of date in an article?
                    <a href="https://github.com/oskar-anderson/portfolio" target="_blank" rel="noopener">Open an issue on GitHub</a>.
                </p>
            </div>

            <div class="hidden lg:block shrink-0 ml-20">
                <img class="object-contain w-full max-w-[360px]" src="/static/img/mail.svg" alt="Mail envelope illustration" />
            </div>
        </div>
    </section>
</Layout>
